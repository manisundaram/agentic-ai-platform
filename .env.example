# =============================================================================
# Application Configuration
# =============================================================================
APP_NAME=agentic-ai-platform
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
MOCK_MODE=false

# =============================================================================
# Server Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# Logging Configuration
# =============================================================================

# Service identification
# APP_NAME and APP_ENV are defined above

# Local logging levels
LOG_LEVEL=INFO                # Console logging level
FILE_LOG_LEVEL=DEBUG          # File logging level
ERROR_FILE_LEVEL=ERROR        # Error file logging level

# Logging format and output
LOG_STRUCTURED=true           # JSON structured logs for production
LOG_CONSOLE=true              # Enable console output
LOG_DIR=./logs                # Directory for log files

# Log file rotation
LOG_MAX_FILE_SIZE=10485760    # 10MB before rotation
LOG_BACKUP_COUNT=5            # Keep 5 old files

# =============================================================================
# Cloud Logging Providers (Optional)
# =============================================================================

# CLOUD_LOGGING_PROVIDERS is the only activation switch.
# Supported values: aws, azure, gcp, datadog
CLOUD_LOGGING_PROVIDERS=[]

# Example:
# CLOUD_LOGGING_PROVIDERS=aws,datadog

# AWS CloudWatch
# AWS_LOGGING_LEVEL=ERROR
# AWS_LOG_GROUP=/agentic-ai-platform/production
# AWS_REGION=us-east-1

# Azure Monitor
# AZURE_LOGGING_LEVEL=ERROR
# AZURE_CONNECTION_STRING=InstrumentationKey=...

# Google Cloud Logging
# GCP_LOGGING_LEVEL=ERROR
# GCP_PROJECT_ID=my-gcp-project

# Datadog
# DATADOG_LOGGING_LEVEL=INFO
# DATADOG_API_KEY=your-datadog-api-key

# =============================================================================
# Provider Configuration
# =============================================================================
# LangSmith / LangChain tracing
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agentic-ai-platform

# Two-level fallback only:
# 1. Family-specific provider key, for example LLM_OPENAI_API_KEY
# 2. Shared provider key, for example OPENAI_API_KEY

# Shared provider for both LLM and embeddings unless overridden below.
# Supported values in this template: openai, gemini, anthropic, mock
PROVIDER=openai

# Optional family split.
# LLM_PROVIDER=gemini
# EMBEDDING_PROVIDER=openai

# OpenAI shared settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenAI family overrides
# LLM_OPENAI_API_KEY=your_llm_openai_api_key_here
# LLM_OPENAI_MODEL=gpt-4o-mini
# EMBEDDING_OPENAI_API_KEY=your_embedding_openai_api_key_here
# EMBEDDING_OPENAI_MODEL=text-embedding-3-small

# Google Gemini shared settings
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Gemini family overrides
# LLM_GEMINI_API_KEY=your_llm_gemini_api_key_here
# LLM_GEMINI_MODEL=gemini-2.5-flash
# EMBEDDING_GEMINI_API_KEY=your_embedding_gemini_api_key_here
# EMBEDDING_GEMINI_MODEL=models/embedding-001

# Anthropic shared settings
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Anthropic family overrides
# LLM_ANTHROPIC_API_KEY=your_llm_anthropic_api_key_here
# LLM_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# EMBEDDING_ANTHROPIC_API_KEY=your_embedding_anthropic_api_key_here
# EMBEDDING_ANTHROPIC_MODEL=custom-embedding-model

# Mock provider shared settings
# PROVIDER=mock
# MOCK_MODEL=mock-default
# MOCK_SEED=0
# MOCK_LATENCY_MS=0

# Mock provider family overrides
# LLM_PROVIDER=mock
# LLM_MOCK_MODEL=mock-llm
# LLM_MOCK_PREFIX=template-
# LLM_MOCK_SUFFIX=-response
# EMBEDDING_PROVIDER=mock
# EMBEDDING_MOCK_MODEL=mock-embed
# EMBEDDING_MOCK_DIMENSION=1536

# =============================================================================
# Vector Store Configuration
# =============================================================================
VECTORSTORE_BACKEND=chroma
DEFAULT_COLLECTION_NAME=default

# =============================================================================
# CORS Configuration
# =============================================================================
ENABLE_CORS=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
